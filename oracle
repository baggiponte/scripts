#!/usr/bin/env bash
#
# oracle - Review implementation/code plans with Codex (gpt-5.2-codex, xhigh)
#
# Usage:
#   oracle [options] [plan-file]
#   cat plan.md | oracle [options]
#
# Options:
#   -o, --output <dir>   Save review markdown to dir (optional)
#   -h, --help           Show help

set -euo pipefail

MODEL="${ORACLE_MODEL:-gpt-5.2-codex}"
REASONING_EFFORT="${ORACLE_REASONING_EFFORT:-xhigh}"
OUTPUT_DIR=""
INPUT_FILE=""

usage() {
  cat <<'EOF'
Usage: oracle [options] [plan-file]
       cat plan.md | oracle [options]

Options:
  -o, --output <dir>     Save review markdown to dir (optional)
  --output=<dir>         Save review markdown to dir (optional)
  -h, --help             Show this help

Environment overrides:
  ORACLE_MODEL             (default: gpt-5.2-codex)
  ORACLE_REASONING_EFFORT  (default: xhigh)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -o|--output)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Error: missing value for --output" >&2
        exit 1
      fi
      OUTPUT_DIR="$1"
      ;;
    --output=*)
      OUTPUT_DIR="${1#*=}"
      ;;
    -*)
      echo "Error: unknown option '$1'" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "${INPUT_FILE}" ]]; then
        echo "Error: too many input files" >&2
        usage >&2
        exit 1
      fi
      INPUT_FILE="$1"
      ;;
  esac
  shift
done

SYSTEM_PROMPT='You are the Oracle: a senior engineer focused on pragmatic excellence.

You review implementation plans (not code) and provide direct, actionable feedback.

Evaluate the plan for:
1. Over-engineering and unnecessary complexity
2. Missing constraints, edge cases, and failure modes
3. Simpler alternatives with lower risk
4. Architectural boundary and coupling problems
5. Practical rollout/testing concerns

Respond with this structure:

### Verdict
One sentence: sound or needs work.

### What Works
Only concrete strengths.

### Critical Issues
Specific problems, why they matter, and likely consequences.

### Recommendations
Concrete improvements and the exact approach you would take.

### Answers to Questions
If questions are included in the plan, answer each directly.

### The Simplest Thing That Could Work
Describe the minimum viable approach that is still robust.'

if [[ -n "${INPUT_FILE}" ]]; then
  if [[ ! -f "${INPUT_FILE}" ]]; then
    echo "Error: input file not found: ${INPUT_FILE}" >&2
    exit 1
  fi
  PLAN_CONTENT="$(cat "${INPUT_FILE}")"
else
  PLAN_CONTENT="$(cat)"
fi

FULL_PROMPT="${SYSTEM_PROMPT}

---

## Plan Submitted for Review

${PLAN_CONTENT}"

echo "Consulting the Oracle (${MODEL}, effort=${REASONING_EFFORT})..." >&2

if [[ -n "${OUTPUT_DIR}" ]]; then
  mkdir -p "${OUTPUT_DIR}"
  OUTPUT_FILE="${OUTPUT_DIR}/oracle-review-$(date +%Y%m%d-%H%M%S).md"
  echo "${FULL_PROMPT}" | codex exec \
    -m "${MODEL}" \
    -c "model_reasoning_effort=\"${REASONING_EFFORT}\"" \
    --sandbox read-only \
    --skip-git-repo-check \
    - | tee "${OUTPUT_FILE}"
  echo "Review saved to: ${OUTPUT_FILE}" >&2
else
  echo "${FULL_PROMPT}" | codex exec \
    -m "${MODEL}" \
    -c "model_reasoning_effort=\"${REASONING_EFFORT}\"" \
    --sandbox read-only \
    --skip-git-repo-check \
    -
fi
