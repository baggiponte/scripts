#! /usr/bin/env zsh

tmux-switcher () {
    local preview_cmd
    local session

    preview_cmd='
session={}

if ! tmux has-session -t "$session" 2>/dev/null; then
    printf "Session not found: %s\n" "$session"
    exit 0
fi

c_reset="$(printf "\033[0m")"
c_title="$(printf "\033[1;36m")"
c_label="$(printf "\033[1;33m")"
c_path="$(printf "\033[0;34m")"

printf "%sSession:%s %s\n" "$c_title" "$c_reset" "$session"
echo

window_count="$(tmux list-windows -t "$session" 2>/dev/null | wc -l | tr -d " ")"
window_i=0

tmux list-windows -t "$session" \
    -F "#{window_index}|#{window_name}|#{window_panes}|#{?window_active,1,0}" 2>/dev/null |
while IFS="|" read -r window_index window_name window_panes window_active; do
    window_i=$((window_i + 1))

    if [ "$window_i" -eq "$window_count" ]; then
        window_branch="└──"
        pane_prefix="    "
    else
        window_branch="├──"
        pane_prefix="│   "
    fi

    if [ "$window_panes" = "1" ]; then
        pane_word="pane"
    else
        pane_word="panes"
    fi

    printf "%s %sWindow %s%s: %s (%s %s)\n" \
        "$window_branch" "$c_label" "$window_index" "$c_reset" "$window_name" "$window_panes" "$pane_word"

    pane_count="$(tmux list-panes -t "${session}:${window_index}" 2>/dev/null | wc -l | tr -d " ")"
    pane_i=0

    tmux list-panes -t "${session}:${window_index}" \
        -F "#{pane_index}|#{?pane_active,1,0}|#{pane_current_command}|#{pane_current_path}" 2>/dev/null |
    while IFS="|" read -r pane_index pane_active pane_command pane_path; do
        pane_i=$((pane_i + 1))

        if [ "$pane_i" -eq "$pane_count" ]; then
            pane_branch="${pane_prefix}└──"
        else
            pane_branch="${pane_prefix}├──"
        fi

        short_path="$(printf "%s" "$pane_path" | sed "s#^${HOME}#~#")"

        printf "%s %sPane %s.%s%s: cmd=%s%s%s path=%s%s%s\n" \
            "$pane_branch" "$c_label" "$window_index" "$pane_index" "$c_reset" \
            "$c_title" "$pane_command" "$c_reset" \
            "$c_path" "$short_path" "$c_reset"
    done
done
'

    session="$(
        tmux list-sessions -F "#{session_name}" | fzf --tmux=center --ansi \
            --preview "$preview_cmd" \
            --preview-window "right,70%,border-left,wrap"
    )"

    if [[ -z "$session" ]]; then
        return
    fi

    if [[ ! -z "$TMUX" ]]; then
        tmux switch-client -t "$session"
    else
        tmux attach -t "$session"
    fi
}

tmux-switcher
