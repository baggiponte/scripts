#!/usr/bin/env bash
#
# reviewer - Review code with Codex (gpt-5.2-codex, xhigh)
#
# Usage:
#   reviewer [options] [review-file]
#   cat review-input.md | reviewer
#
# Options:
#   -o, --output <file>   Save review output to file (optional)
#   -h, --help            Show help

set -euo pipefail

MODEL="${REVIEWER_MODEL:-gpt-5.2-codex}"
REASONING_EFFORT="${REVIEWER_REASONING_EFFORT:-xhigh}"
OUTPUT_FILE=""
INPUT_FILE=""

usage() {
  cat <<'EOF'
Usage: reviewer [options] [review-file]
       cat review-input.md | reviewer

Options:
  -o, --output <file>     Save review output to file (optional)
  --output=<file>         Save review output to file (optional)
  -h, --help              Show this help

Environment overrides:
  REVIEWER_MODEL             (default: gpt-5.2-codex)
  REVIEWER_REASONING_EFFORT  (default: xhigh)
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -o|--output)
      shift
      if [[ $# -eq 0 ]]; then
        echo "Error: missing value for --output" >&2
        exit 1
      fi
      OUTPUT_FILE="$1"
      ;;
    --output=*)
      OUTPUT_FILE="${1#*=}"
      ;;
    -*)
      echo "Error: unknown option '$1'" >&2
      usage >&2
      exit 1
      ;;
    *)
      if [[ -n "${INPUT_FILE}" ]]; then
        echo "Error: too many input files" >&2
        usage >&2
        exit 1
      fi
      INPUT_FILE="$1"
      ;;
  esac
  shift
done

if [[ -n "${INPUT_FILE}" ]]; then
  if [[ ! -f "${INPUT_FILE}" ]]; then
    echo "Error: input file not found: ${INPUT_FILE}" >&2
    exit 1
  fi
  REVIEW_INPUT="$(cat "${INPUT_FILE}")"
else
  REVIEW_INPUT="$(cat)"
fi

SYSTEM_PROMPT='You are Reviewer: a strict, pragmatic senior code reviewer.

You review code and tests only. You do not write code or apply changes.

Priorities:
1. Type safety and correctness (type contracts, nullability, narrowing, generics, unsafe casts)
2. Behavioral correctness
3. Test quality and test intent
4. Maintainability and complexity

Testing standards:
- Verify tests actually check behavior that matters.
- Prefer meaningful assertions over implementation-coupled assertions.
- Highlight missing edge cases, error paths, and regressions.
- Be skeptical of excessive mocks. Use mocks only when isolation is necessary (network, time, randomness, external services, expensive side effects). If a mock can be replaced by a real collaborator or lightweight fake, say so.

Response format (findings first):

### Findings
List issues by severity (High, Medium, Low) with file/line references when available.
If no issues, explicitly say "No significant findings."

### Test Review
Assess whether tests validate the right behavior, and what is missing.

### Type Review
Assess type soundness risks and improvements.

### Open Questions
Only unresolved assumptions that block confidence.

### Verdict
One sentence overall judgment.'

FULL_PROMPT="${SYSTEM_PROMPT}

---

## Code/Test Material To Review

${REVIEW_INPUT}"

echo "Running reviewer (${MODEL}, effort=${REASONING_EFFORT})..." >&2

if [[ -n "${OUTPUT_FILE}" ]]; then
  echo "${FULL_PROMPT}" | codex exec \
    -m "${MODEL}" \
    -c "model_reasoning_effort=\"${REASONING_EFFORT}\"" \
    --sandbox read-only \
    --skip-git-repo-check \
    - | tee "${OUTPUT_FILE}"
  echo "Review saved to: ${OUTPUT_FILE}" >&2
else
  echo "${FULL_PROMPT}" | codex exec \
    -m "${MODEL}" \
    -c "model_reasoning_effort=\"${REASONING_EFFORT}\"" \
    --sandbox read-only \
    --skip-git-repo-check \
    -
fi
